# AI DevOps Orchestrator Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# AI & LLM Configuration
# =============================================================================

# Choose your AI provider (uncomment one)
# OPENAI_API_KEY=sk-...                    # OpenAI GPT-4/GPT-3.5
# ANTHROPIC_API_KEY=sk-ant-...             # Anthropic Claude
# GOOGLE_AI_API_KEY=AIza...                # Google Gemini

# Default AI model for analysis
AI_MODEL=gpt-4-turbo                       # Options: gpt-4-turbo, claude-3-sonnet, gemini-pro

# =============================================================================
# GitHub Integration
# =============================================================================

# GitHub Personal Access Token (with repo, workflow permissions)
GITHUB_TOKEN=ghp_...

# GitHub organization/user for repositories to monitor
GITHUB_ORG=your-organization

# Webhook secret for GitHub integration
GITHUB_WEBHOOK_SECRET=your-random-secret-string

# =============================================================================
# Project Configuration
# =============================================================================

# Webhook URL for project events (automatically set by n8n)
PROJECT_WEBHOOK_URL=http://localhost:5678/webhook/project-events

# Projects to monitor (comma-separated repository names)
MONITORED_PROJECTS=my-nextjs-app,my-django-api,my-react-frontend

# Default branch to monitor
DEFAULT_BRANCH=main

# =============================================================================
# Database Configuration (ChromaDB)
# =============================================================================

# ChromaDB configuration
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME=devops_knowledge

# Persistent storage path
CHROMADB_PERSIST_DIRECTORY=/app/chromadb_data

# =============================================================================
# n8n Workflow Automation
# =============================================================================

# n8n configuration
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# n8n webhook URL (for external triggers)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# n8n execution timeout (in seconds)
N8N_EXECUTION_TIMEOUT=300

# =============================================================================
# Notification Channels
# =============================================================================

# Slack integration (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL=#devops-alerts

# Discord integration (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=AI DevOps <noreply@your-domain.com>
# EMAIL_TO=devops-team@your-domain.com

# =============================================================================
# Security & Access Control
# =============================================================================

# JWT secret for API authentication
JWT_SECRET=your-random-jwt-secret

# API rate limiting
RATE_LIMIT_MAX=100                         # Max requests per minute per IP
RATE_LIMIT_WINDOW=60                       # Rate limit window in seconds

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5678

# =============================================================================
# Docker & Infrastructure
# =============================================================================

# Docker registry for storing built images
DOCKER_REGISTRY=ghcr.io/your-org

# Docker repository prefix
DOCKER_REPO_PREFIX=ai-devops

# GCP Configuration (if using Google Cloud)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json

# AWS Configuration (if using AWS)
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Log level
LOG_LEVEL=INFO                            # Options: DEBUG, INFO, WARNING, ERROR

# Sentry for error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...

# Metrics collection
ENABLE_METRICS=true
METRICS_PORT=9090

# Health check endpoints
HEALTH_CHECK_INTERVAL=30                  # Seconds between health checks
HEALTH_CHECK_TIMEOUT=10                   # Health check timeout in seconds

# =============================================================================
# Advanced Configuration
# =============================================================================

# AI analysis confidence threshold (0.0 - 1.0)
AI_CONFIDENCE_THRESHOLD=0.7

# Maximum number of concurrent analysis jobs
MAX_CONCURRENT_ANALYSES=5

# Vector similarity threshold for pattern matching
SIMILARITY_THRESHOLD=0.8

# Auto-fix approval threshold (0.0 - 1.0)
AUTO_FIX_THRESHOLD=0.9

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Cache configuration
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600                           # Cache TTL in seconds

# =============================================================================
# Framework-Specific Configuration
# =============================================================================

# Next.js specific settings
NEXTJS_BUILD_COMMAND=pnpm build
NEXTJS_TEST_COMMAND=pnpm test

# Django specific settings
DJANGO_MANAGE_COMMAND=python manage.py
DJANGO_REQUIREMENTS_FILE=requirements.txt

# React specific settings
REACT_BUILD_COMMAND=npm run build
REACT_TEST_COMMAND=npm test

# Vue.js specific settings
VUE_BUILD_COMMAND=npm run build
VUE_TEST_COMMAND=npm run test:unit

# Spring Boot specific settings
SPRING_BUILD_COMMAND=./gradlew build
SPRING_TEST_COMMAND=./gradlew test